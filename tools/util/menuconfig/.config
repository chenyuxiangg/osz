
#
# Architecture Configuration
#
CONFIG_OSZ_CFG_RISCV=y
CONFIG_OSZ_CFG_INTERRUPT_STACK_SIZE=0x800
CONFIG_OSZ_CFG_EXCEPTION_STACK_SIZE=0x800
# end of Architecture Configuration

#
# Object Configuration
#
CONFIG_OSZ_CFG_OBJ_NAME_MAX_LENS=8
# end of Object Configuration

#
# Kernel Base Configuration
#
CONFIG_OSZ_CFG_INIT=y
CONFIG_OSZ_CFG_HOOK=y
CONFIG_OSZ_CFG_DFX=y
CONFIG_OSZ_CFG_STARTUP=y
CONFIG_OSZ_CFG_STRUCT=y
CONFIG_OSZ_CFG_STRUCT_DLINK=y
CONFIG_OSZ_CFG_STRUCT_FIFO=y
CONFIG_OSZ_CFG_STRUCT_SORTLINK=y
CONFIG_OSZ_CFG_COMM=y
CONFIG_OSZ_CFG_MEM=y
CONFIG_OSZ_CFG_BESTFIT=y
CONFIG_OSZ_CFG_DEBUG=y
CONFIG_OSZ_CFG_TRAP=y
CONFIG_OSZ_CFG_EXCEPTION=y
CONFIG_OSZ_CFG_INTERRUPT=y
CONFIG_OSZ_CFG_STARTUP_STACK_SIZE=0x400
CONFIG_OSZ_CFG_PRI_QUEUE_LIMIT=0x20
CONFIG_OSZ_CFG_IPC=y
CONFIG_OSZ_CFG_SEM=y
CONFIG_OSZ_SEM_STATIC_MAX_CNT=10
CONFIG_OSZ_CFG_EVENT=y
CONFIG_OSZ_EVENT_STATIC_MAX_CNT=10
CONFIG_OSZ_CFG_MUTEX=y
CONFIG_OSZ_MUTEX_STATIC_MAX_CNT=10
CONFIG_OSZ_CFG_ATOMIC=y
CONFIG_OSZ_CFG_SOFTTIMER=y
CONFIG_OSZ_CFG_SOFTTIMER_TASK_STACK=0x1000
CONFIG_OSZ_CFG_SOFTTIMER_TASK_PRIORITY=9
CONFIG_OSZ_CFG_SWT_MAX=0x20
# end of Kernel Base Configuration

#
# Kernel Task Configuration
#
CONFIG_OSZ_CFG_TASK=y
CONFIG_OSZ_CFG_SCHEDULE=y
# CONFIG_OSZ_CFG_COORDINATION is not set
CONFIG_OSZ_CFG_PREEMPTION=y
CONFIG_OSZ_CFG_TASK_STACK_DEFAULT_SIZE=0x2000
CONFIG_OSZ_CFG_TASK_LIMIT=16
CONFIG_OSZ_CFG_TASK_PRI_LOWEST=31
CONFIG_OSZ_CFG_TASK_TICK_PER_US=10
# end of Kernel Task Configuration

#
# Kernel Interrupt Configuration
#
CONFIG_OSZ_CFG_INT_LIMIT=90
# end of Kernel Interrupt Configuration

#
# Base Driver Configuration
#
CONFIG_OSZ_CFG_DRIVERS=y
CONFIG_OSZ_CFG_UART=y
CONFIG_OSZ_CFG_TIMER=y
# end of Base Driver Configuration

#
# Platform Configuration
#
CONFIG_OSZ_CFG_PLATFORM="qemu_virt"
# end of Platform Configuration

#
# Target Configuration
#
CONFIG_OSZ_CFG_TARGETS=y
# end of Target Configuration

#
# Shell Configuration
#
CONFIG_OSZ_CFG_SHELL=y
CONFIG_OSZ_CFG_SHELL_HISTORY_CMD_NUM=10
# end of Shell Configuration
